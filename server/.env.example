# Ante backend — environment.
# Copy to `.env` and fill in. The Turnkey parent-org API key MUST stay here on
# the server; it can create sub-orgs and must never be shipped to the browser.

PORT=8787
# Origin allowed to call this API (the Ante frontend dev server by default).
ALLOWED_ORIGIN=http://localhost:5173

# --- Turnkey (parent organization) -----------------------------------------
# From your Turnkey dashboard. Create an API key pair for the PARENT org.
TURNKEY_API_BASE_URL=https://api.turnkey.com
TURNKEY_ORGANIZATION_ID=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
