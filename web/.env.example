# Ante frontend — environment variables.
# Copy to `.env.local` and fill in. All vars are read at build time via
# import.meta.env. Anything left blank falls back to a TODO(facts) placeholder
# and the widget shows a "configure your env" banner instead of talking to a
# wrong endpoint.

# --- Chain (verified Tempo Testnet "Moderato" defaults; override if needed) -
# These match the baked-in fallbacks in src/config/chain.ts, so you only NEED
# to set VITE_ANTE_ADDRESS (after deploy) and a dev key below.
VITE_RPC_URL=https://rpc.moderato.tempo.xyz
VITE_CHAIN_ID=42431

# Deployed Ante contract address — set this AFTER running `forge script Deploy`
# in ../contracts. Until set, the widget shows a "configure your env" banner.
VITE_ANTE_ADDRESS=

# Stake token: pathUSD (Tempo testnet stablecoin, 6 decimals). Fund via the
# faucet: RPC method `tempo_fundAddress <addr>` or POST docs.tempo.xyz/api/faucet.
VITE_TOKEN_ADDRESS=0x20c0000000000000000000000000000000000000

# --- Feed sync (optional; sensible defaults) -------------------------------
# Block the contract was deployed at. The feed cold-scan starts here instead of
# block 0 — set it after deploy to avoid scanning pre-deploy history. Default 0.
VITE_DEPLOY_BLOCK=
# Max block span per eth_getLogs call. The cold scan paginates into windows of
# this size to respect public-RPC range caps. Default 9000.
VITE_LOG_RANGE=

# --- Moderation -------------------------------------------------------------
# The moderator "Resolve ▸ Uphold / Reject" panel appears when the connected
# wallet is a moderator on-chain (read from the `moderators(address)` mapping).
# Set this to `true` to FORCE the panel on without that read — handy for local
# dev / demos before the contract is deployed. Leave blank in normal use; the
# on-chain check governs. The contract still enforces moderator-only at the
# transaction level regardless of this flag.
VITE_IS_MODERATOR=

# --- Wallet: dev fallback (testnet ONLY) -----------------------------------
# A throwaway testnet private key (0x + 64 hex). Used by DevWalletProvider so
# the app runs end-to-end without the Turnkey passkey flow. NEVER use a real /
# funded-with-real-money key here — it is bundled into the client.
VITE_DEV_PRIVATE_KEY=

# --- Wallet: Turnkey passkey (optional; takes precedence if all set) --------
# When all four are present, the app uses the Turnkey embedded-wallet passkey
# path instead of the dev key. See src/wallet/TurnkeyWalletProvider.ts.
# TODO(facts): exact values + whether a backend proxy is needed — see
# docs/tempo-facts.md (research agent).
VITE_TURNKEY_ORGANIZATION_ID=
VITE_TURNKEY_API_BASE_URL=
VITE_TURNKEY_RP_ID=
# The provisioned Turnkey wallet account address to sign with.
VITE_TURNKEY_SIGN_WITH=
